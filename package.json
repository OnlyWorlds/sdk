{
  "name": "@onlyworlds/sdk",
  "version": "4.0.0-alpha.0",
  "description": "TypeScript SDK for the OnlyWorlds API - build world-building applications with type safety",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "types": "dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "pretest": "npm run build",
    "test": "node --test \"test/**/*.test.mjs\"",
    "codegen": "python codegen/generate_types.py",
    "codegen:check": "python codegen/generate_types.py --check",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "onlyworlds",
    "worldbuilding",
    "api",
    "sdk",
    "typescript",
    "rpg",
    "ttrpg",
    "game-development"
  ],
  "author": "OnlyWorlds",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/OnlyWorlds/sdk.git"
  },
  "homepage": "https://onlyworlds.github.io/",
  "bugs": {
    "url": "https://github.com/OnlyWorlds/sdk/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
